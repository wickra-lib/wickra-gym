# The wickra-gym C ABI header and library are provided out-of-tree via the
# WKGYM_INC (include dir) and WKGYM_LIB (library dir) environment variables, set
# by CI / the installer. The Makevars do not bake an rpath; the loader must find
# the shared library via LD_LIBRARY_PATH / DYLD_LIBRARY_PATH at run time.
PKG_CPPFLAGS = -I$(WKGYM_INC)
PKG_LIBS = -L$(WKGYM_LIB) -lwickra_gym
